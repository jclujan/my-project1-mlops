# ── Secrets — NEVER commit these ─────────────────
.env

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# ── Environments ──────────────────────────────────
.venv/
venv/
env/

# ── Tooling ───────────────────────────────────────
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
dist/
build/

# ── OS and IDE ────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ── Data — keep folder structure, ignore contents ─
data/*
!data/raw/
!data/processed/
!data/inference/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/inference/.gitkeep

# ── Model artifacts ───────────────────────────────
models/*
!models/.gitkeep

# ── Reports and outputs ───────────────────────────
reports/*
!reports/.gitkeep

# ── Logs ──────────────────────────────────────────
logs/*
!logs/.gitkeep
*.log

